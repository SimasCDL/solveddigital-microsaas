    "Faq": { "cardMode": "single", "viewport": "1000x720" },
    "FinalCta": { "cardMode": "single", "viewport": "1200x560" },
    "Nav": { "cardMode": "single", "viewport": "1280x140" },
    "PromoBar": { "cardMode": "single", "viewport": "1280x90" },
