# Copy to .env.local and fill in. Never commit .env.local.

# Anthropic — photo sorting + clip quality control
ANTHROPIC_API_KEY=

# fal.ai — video generation
FAL_KEY=

# Access key for the internal /generate and /bakeoff tools
ADMIN_KEY=

# Cost protection: hard cap on video generations per day
DAILY_CLIP_LIMIT=150

# Stripe — payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — delivery emails
RESEND_API_KEY=
FROM_EMAIL=orders@yourdomain.com

# Supabase — history + video storage (falls back to local .orders/ if unset)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Deployed URL (used in emails/links)
NEXT_PUBLIC_APP_URL=

# Microsoft Clarity — session recordings + heatmaps (project ID from clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ── Daily report (Telegram cron at 20:00 UTC = 23:00 Vilnius) ──
# Clarity Data Export API token (Clarity → Settings → Data Export)
CLARITY_API_TOKEN=
# Telegram bot token (@BotFather) + target chat/group id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Shared secret protecting /api/daily-report (Vercel Cron sends it automatically)
CRON_SECRET=
